---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A curated directory of open-source cloud security tools. Find, filter, and evaluate the best tools for your needs." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="A curated directory of open-source cloud security tools. Find, filter, and evaluate the best tools for your needs." />
    <meta property="og:url" content="https://cloudsectools.com" />
    <meta property="og:type" content="website" />
    <meta name="author" content="Jonathan Thompson" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900 font-sans">
    <slot />
  </body>
</html>

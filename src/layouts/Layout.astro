---
interface Props {
  title: string;
  canonical?: string;
}
const { title, canonical = 'https://cloudsectools.dev/' } = Astro.props;
const description = 'A curated directory of open-source cloud security tools. Find, filter, and evaluate the best tools for your needs.';
const siteName = 'CloudSecTools';
const siteUrl = 'https://cloudsectools.dev/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description,
  publisher: {
    '@type': 'Organization',
    name: 'Thompson InfoSec',
    url: 'https://thompsoninfosec.com',
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="author" content="Jonathan Thompson" />
    <meta name="theme-color" content="#0ea5e9" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-900 font-sans">
    <slot />
  </body>
</html>
